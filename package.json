{
  "name": "TheAiGuide",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "build:cf": "opennextjs-cloudflare build",
    "preview:cf": "opennextjs-cloudflare preview",
    "deploy:cf": "opennextjs-cloudflare deploy",
    "generate": "pnpm --dir spacetimedb install && cargo run -p gen-bindings -- --out-dir src/module_bindings --module-path spacetimedb && node scripts/patch-spacetimedb-bindings.mjs && prettier --write src/module_bindings",
    "spacetime:generate": "spacetime generate --lang typescript --out-dir src/module_bindings --module-path spacetimedb && node scripts/patch-spacetimedb-bindings.mjs",
    "spacetime:publish:local": "spacetime publish theaiguide-ol2uu --module-path spacetimedb --server local --delete-data",
    "spacetime:publish": "spacetime publish theaiguide-ol2uu --module-path spacetimedb --server maincloud"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.38.2",
    "@tailwindcss/postcss": "^4.2.1",
    "next": "^15.0.0",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "spacetimedb": "2.1.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@types/node": "^20",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "typescript": "~5.6.2",
    "wrangler": "^4.69.0"
  }
}